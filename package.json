{
  "name": "easyassets-launcher",
  "version": "0.1.0",
  "private": true,
  "description": "EasyAssets Launcher",
  "scripts": {
    "dev":              "node scripts/embed-bridge.js && tauri dev",
    "build":            "node scripts/embed-bridge.js && tauri build",
    "build:win":        "node scripts/embed-bridge.js && tauri build --target x86_64-pc-windows-msvc",
    "build:win:portable": "node scripts/embed-bridge.js && tauri build --target x86_64-pc-windows-msvc --no-bundle",
    "embed-bridge":     "node scripts/embed-bridge.js",
    "tauri":            "tauri"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  },
  "dependencies": {
    "@tauri-apps/api": "^2"
  }
}
